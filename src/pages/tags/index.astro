---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const allPosts = await getCollection('blog');

const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const maxCount = tags.length > 0 ? tags[0].count : 1;
---

<BlogLayout title="标签">
  <header class="mb-10">
    <p class="text-sm text-[var(--color-primary)] font-medium mb-2 tracking-wide uppercase">Tags</p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">标签云</h1>
    <p class="text-[var(--color-text-secondary)]">
      共 <span class="text-[var(--color-primary)] font-semibold">{tags.length}</span> 个标签
    </p>
  </header>

  <div class="flex flex-wrap gap-2.5 py-4">
    {tags.map((tag) => {
      const ratio = tag.count / maxCount;
      const sizeClass = ratio > 0.7 ? 'text-base px-4 py-2' : ratio > 0.3 ? 'text-sm px-3.5 py-1.5' : 'text-xs px-3 py-1.5';
      return (
        <a
          href={`/tags/${tag.name}`}
          class={`bg-[var(--color-card)] dark:bg-[var(--color-card)] rounded-full border border-[var(--color-border)] hover:bg-[var(--color-accent-wash)] hover:border-[var(--color-primary)]/20 hover:text-[var(--color-primary)] dark:hover:text-[var(--color-primary)] transition-all duration-300 ${sizeClass}`}
        >
          <span class="font-medium">{tag.name}</span>
          <sup class="text-[10px] text-[var(--color-text-quiet)] ml-0.5">{tag.count}</sup>
        </a>
      );
    })}
  </div>
</BlogLayout>
