---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  if (page === 1) return baseUrl;
  return `${baseUrl}${baseUrl.endsWith('/') ? '' : '/'}page/${page}`;
}
---

{
  totalPages > 1 && (
    <nav class="flex items-center justify-center gap-2 mt-10">
      {
        currentPage > 1 && (
          <a
            href={pageUrl(currentPage - 1)}
            class="px-4 py-2 rounded-full bg-[var(--color-card)] dark:bg-[var(--color-card)] border border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/20 transition-all duration-300"
          >
            上一页
          </a>
        )
      }
      {
        Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
          <a
            href={pageUrl(page)}
            class={`px-4 py-2 rounded-full text-sm transition-all duration-300 ${
              page === currentPage
                ? 'bg-[var(--color-primary)] text-white border border-[var(--color-primary)]'
                : 'bg-[var(--color-card)] dark:bg-[var(--color-card)] border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/20'
            }`}
          >
            {page}
          </a>
        ))
      }
      {
        currentPage < totalPages && (
          <a
            href={pageUrl(currentPage + 1)}
            class="px-4 py-2 rounded-full bg-[var(--color-card)] dark:bg-[var(--color-card)] border border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/20 transition-all duration-300"
          >
            下一页
          </a>
        )
      }
    </nav>
  )
}
