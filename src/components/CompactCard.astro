---
import { getWordCount } from '@/utils/readingTime';

interface Props {
  title: string;
  description?: string;
  date: Date;
  slug: string;
  tags?: string[];
  category?: string;
  body?: string;
  cover?: string;
  pinned?: boolean;
  draft?: boolean;
  routePrefix?: string;
}

const {
  title,
  description,
  date,
  slug,
  tags = [],
  category,
  body,
  cover,
  pinned = false,
  draft = false,
  routePrefix = '/post/',
} = Astro.props;

const wordCount = body ? getWordCount(body) : 0;

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<article
  class="group relative bg-[var(--color-card)] dark:bg-[var(--color-card)] rounded-xl overflow-hidden border border-[var(--color-border)] hover:bg-[var(--color-card-raised)] dark:hover:bg-[var(--color-card-raised)] hover:border-[var(--color-primary)]/15 transition-all duration-300"
  transition:animate="fade"
>
  <a href={`${routePrefix}${slug}`} class="block">
    {cover ? (
      <div class="aspect-[16/9] overflow-hidden relative">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
    ) : (
      <div class="aspect-[16/9] bg-gradient-to-br from-[var(--color-primary)]/8 via-[var(--color-primary)]/3 to-transparent relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="relative">
            <div class="absolute -inset-8 bg-[var(--color-primary)]/5 rounded-full blur-xl"></div>
            <span class="relative text-5xl font-bold text-[var(--color-primary)]/15 group-hover:text-[var(--color-primary)]/25 transition-colors duration-500">
              {title.charAt(0)}
            </span>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[var(--color-primary)]/10 to-transparent"></div>
      </div>
    )}

    <div class="p-4">
      <div class="flex items-start justify-between gap-3 mb-2">
        <h2 class="text-[18px] font-semibold leading-snug group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
          {title}
        </h2>
        <div class="flex items-center gap-1.5 shrink-0">
          {pinned && (
            <span class="inline-flex items-center gap-0.5 text-[10px] font-medium text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20 px-1.5 py-0.5 rounded-full">
              置顶
            </span>
          )}
          {draft && (
            <span class="inline-flex items-center text-[10px] font-medium text-[var(--color-text-quiet)] bg-[var(--color-bg)] dark:bg-white/[0.04] px-1.5 py-0.5 rounded-full">
              编辑中
            </span>
          )}
        </div>
      </div>

      {description && (
        <p class="text-xs text-[var(--color-text-secondary)] line-clamp-2 leading-relaxed mb-3">
          {description}
        </p>
      )}

      <div class="flex items-center gap-3 text-[11px] text-[var(--color-text-quiet)]">
        <time datetime={formatDate(date)}>{formatDate(date)}</time>
        {category && (
          <>
            <span class="w-px h-3 bg-[var(--color-border)]"></span>
            <span>{category}</span>
          </>
        )}
        {wordCount > 0 && (
          <>
            <span class="w-px h-3 bg-[var(--color-border)]"></span>
            <span>{wordCount} 字</span>
          </>
        )}
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-bg)] dark:bg-white/[0.04] text-[var(--color-text-quiet)] border border-[var(--color-border)]">
              {tag}
            </span>
          ))}
          {tags.length > 3 && (
            <span class="text-[10px] px-2 py-0.5 text-[var(--color-text-quiet)]">
              +{tags.length - 3}
            </span>
          )}
        </div>
      )}
    </div>
  </a>
</article>
