---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_COVER } from '@/consts';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src={SITE_COVER}
      alt=""
      class="w-full h-full object-cover scale-105"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-[#111318]/70"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#4b6bff]/[0.03] via-transparent to-transparent"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-28 sm:pt-32 lg:pt-36 pb-20 sm:pb-24 lg:pb-28">
    <div class="max-w-2xl">
      <h1
        class="text-4xl sm:text-5xl font-semibold text-white tracking-tight leading-[1.02] mb-4 hero-reveal"
        data-hero-reveal
      >
        {SITE_TITLE}
      </h1>
      <p
        class="text-base sm:text-lg text-white/50 font-light leading-relaxed hero-reveal"
        data-hero-reveal
      >
        {SITE_DESCRIPTION}
      </p>
    </div>
  </div>
</section>

<script is:inline>
  import gsap from 'gsap';

  function initHero() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const reveals = document.querySelectorAll('[data-hero-reveal]');
    if (reveals.length === 0) return;

    gsap.fromTo(reveals,
      { opacity: 0, y: 20 },
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.1,
        ease: 'power3.out',
        delay: 0.1,
      }
    );
  }

  initHero();
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initHero, 100);
  });
</script>
