---
import { getCollection } from 'astro:content';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_AVATAR, SOCIAL_LINKS } from '@/consts';

const allPosts = await getCollection('blog');

const categoryMap = new Map<string, number>();
const tagMap = new Map<string, number>();

for (const post of allPosts) {
  const cat = post.data.category;
  if (cat) {
    const rootCat = cat.split('/')[0];
    categoryMap.set(rootCat, (categoryMap.get(rootCat) || 0) + 1);
  }
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const allCategories = Array.from(categoryMap.entries()).sort((a, b) => b[1] - a[1]);
const allTags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);
---

<aside class="space-y-4">
  <div class="bg-white/80 dark:bg-[var(--color-card)] backdrop-blur-sm rounded-xl p-4 border border-[var(--color-border)]">
    <div class="flex items-center gap-3 mb-3">
      <img
        src={SITE_AVATAR}
        alt={SITE_AUTHOR}
        class="w-12 h-12 rounded-full object-cover ring-2 ring-[var(--color-primary)]/20"
        width="48"
        height="48"
      />
      <div>
        <h3 class="font-semibold text-sm text-[var(--color-text)]">{SITE_AUTHOR}</h3>
      </div>
    </div>
    <div class="flex items-center gap-2">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="w-7 h-7 flex items-center justify-center rounded-full bg-[var(--color-bg)] dark:bg-white/[0.04] text-[var(--color-text-quiet)] hover:text-[var(--color-primary)] hover:bg-[var(--color-accent-wash)] transition-all"
          title={link.name}
        >
          {link.icon === 'github' && (
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          )}
          {link.icon === 'rss' && (
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>

  {allCategories.length > 0 && (
    <div class="bg-white/80 dark:bg-[var(--color-card)] backdrop-blur-sm rounded-xl p-4 border border-[var(--color-border)]">
      <h2 class="text-xs font-medium text-[var(--color-text-quiet)] uppercase tracking-widest mb-3">
        分类
      </h2>
      <div class="flex flex-wrap gap-2">
        {allCategories.map(([name, count]) => (
          <a
            href={`/categories/${name}`}
            class="filter-chip inline-flex items-center gap-1 text-xs px-3 py-1.5 rounded-full bg-[var(--color-bg)] dark:bg-white/[0.04] text-[var(--color-text-secondary)] border border-[var(--color-border)] hover:bg-[var(--color-accent-wash)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/20 transition-all"
          >
            {name}
            <span class="opacity-50">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  {allTags.length > 0 && (
    <div class="bg-white/80 dark:bg-[var(--color-card)] backdrop-blur-sm rounded-xl p-4 border border-[var(--color-border)]">
      <h2 class="text-xs font-medium text-[var(--color-text-quiet)] uppercase tracking-widest mb-3">
        标签
      </h2>
      <div class="flex flex-wrap gap-2">
        {allTags.slice(0, 20).map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="filter-chip inline-flex items-center gap-1 text-xs px-3 py-1.5 rounded-full bg-[var(--color-bg)] dark:bg-white/[0.04] text-[var(--color-text-secondary)] border border-[var(--color-border)] hover:bg-[var(--color-accent-wash)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/20 transition-all"
          >
            {tag}
            <span class="opacity-50">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}
</aside>
